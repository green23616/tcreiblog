# Supabase project URL — found in Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — found in Project Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OAuth (Google + GitHub) is configured in Supabase Dashboard > Authentication > Providers
# No additional env vars required in Next.js — Supabase handles the OAuth flow.
# Callback URL to register with each provider:
#   https://your-project-ref.supabase.co/auth/v1/callback
